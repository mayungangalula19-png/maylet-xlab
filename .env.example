# Copy this file to .env and fill in your real values.
# Vite loads .env only (not .env.example).

# ── Supabase (required) ─────────────────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ── App ───────────────────────────────────────────────────────
VITE_APP_URL=http://localhost:5173

# ── AI keys (browser / Vite — bundled into frontend) ─────────
# AI Analyze: OpenRouter (preferred) OR Groq fallback:
VITE_OPENROUTER_API_KEY=your-openrouter-key

# MAYA chat + AI Analyze fallback when maya-chat edge function is not deployed:
# Get a free key at https://console.groq.com
VITE_GROQ_API_KEY=your-groq-key
VITE_GEMINI_API_KEY=your-gemini-key
VITE_DEEPSEEK_API_KEY=your-deepseek-key
VITE_OPENAI_API_KEY=your-openai-key

# Optional: WebSocket messaging gateway (server/messaging)
# VITE_MESSAGING_WS_URL=ws://localhost:8787

# VITE_NEWSLETTER_API_URL=https://your-project.supabase.co

# ── Supabase Edge Function secrets (server-side, NOT in .env) ─
# Set in Supabase Dashboard → Edge Functions → Secrets, or:
#   supabase secrets set GROQ_API_KEY=your-groq-key
# Required for MAYA Assistant (maya-chat function):
#   GROQ_API_KEY
# Newsletter welcome emails (newsletter-subscribe function):
#   RESEND_API_KEY
#   NEWSLETTER_FROM_EMAIL=Maylet XLab <newsletter@mayletxlab.com>
#   SUPABASE_SERVICE_ROLE_KEY
# Optional for maya-alerts / maya-embed:
#   SUPABASE_SERVICE_ROLE_KEY
