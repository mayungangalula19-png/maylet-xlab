{
  "name": "maylet-xlab",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run typecheck && vite build",
    "typecheck": "tsc -b",
    "lint": "eslint .",
    "test": "vitest run",
    "audit:circular": "node scripts/check-circular-deps.mjs",
    "audit:routes": "node scripts/generate-route-inventory.mjs",
    "audit:route-deps": "node scripts/audit-route-deps.mjs",
    "audit:architecture": "npm run typecheck && npm run audit:circular && npm run audit:routes && npm run audit:route-deps",
    "preview": "vite preview",
    "verify:metadata": "node --env-file=.env scripts/verify-project-metadata.mjs",
    "verify:realtime": "node --env-file=.env scripts/verify-realtime.mjs",
    "verify:db": "node --env-file=.env scripts/verify-project-metadata.mjs && node --env-file=.env scripts/verify-realtime.mjs"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.106.1",
    "chart.js": "^4.5.1",
    "react": "^19.2.5",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.15.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.10",
    "vitest": "^4.1.9"
  }
}
